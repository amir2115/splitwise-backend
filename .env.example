APP_NAME=OfflineSplitwise Backend
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1
HOST=127.0.0.1
PORT=8000

DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/offline_splitwise

JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=14
APP_DOWNLOAD_ADMIN_SECRET=
CORS_ALLOW_ORIGINS=https://splitwise.ir,https://www.splitwise.ir,http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173
