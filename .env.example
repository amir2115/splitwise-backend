APP_NAME=OfflineSplitwise Backend
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1
HOST=127.0.0.1
PORT=8000

DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/offline_splitwise

JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=14
ADMIN_PANEL_USERNAME=admin
ADMIN_PANEL_PASSWORD=
ADMIN_PANEL_PASSWORD_HASH=
ADMIN_PANEL_JWT_SECRET=
ADMIN_PANEL_ACCESS_TOKEN_EXPIRE_MINUTES=480
ADMIN_PANEL_RATE_LIMIT_ATTEMPTS=5
ADMIN_PANEL_RATE_LIMIT_WINDOW_MINUTES=10
ADMIN_PANEL_RATE_LIMIT_LOCKOUT_MINUTES=15
PHONE_VERIFICATION_REQUIRED=false
SMS_IR_API_KEY=
SMS_IR_VERIFY_TEMPLATE_ID=
SMS_IR_VERIFY_TEMPLATE_ID_ANDROID=
SMS_IR_VERIFY_PARAMETER_NAME=OTP
SMS_IR_INVITED_ACCOUNT_TEMPLATE_ID=
SMS_IR_INVITED_ACCOUNT_LINK_PARAMETER_NAME=LINK
SMS_IR_INVITED_ACCOUNT_GROUP_NAME_PARAMETER_NAME=GROUP_NAME
WEB_APP_BASE_URL=https://pwa.splitwise.ir
PHONE_VERIFICATION_CODE_LENGTH=5
PHONE_VERIFICATION_TTL_SECONDS=120
PHONE_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
PHONE_VERIFICATION_MAX_VERIFY_ATTEMPTS=5
PHONE_VERIFICATION_MAX_SEND_ATTEMPTS_PER_WINDOW=3
APP_DOWNLOAD_ADMIN_SECRET=
APP_DOWNLOAD_UPLOAD_DIR=/files
APP_DOWNLOAD_PUBLIC_BASE_URL=https://api.splitwise.ir
ARTICLE_IMAGE_UPLOAD_DIR=/files/articles
ARTICLE_IMAGE_PUBLIC_BASE_URL=https://api.splitwise.ir
CORS_ALLOW_ORIGINS=https://splitwise.ir,https://www.splitwise.ir,https://panel.splitwise.ir,http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173
CORS_ALLOW_ORIGIN_REGEX=^https://([a-z0-9-]+\.)?splitwise\.ir$|^http://(localhost|127\.0\.0\.1)(:\d+)?$
