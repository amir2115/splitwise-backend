COMPOSE_PROJECT_NAME=offline_splitwise

# Build contexts. Keep these defaults for local all-in-one checkout.
# On the server, point each value at the matching clone if repos are separated.
BACKEND_CONTEXT=.
LANDING_CONTEXT=/opt/offline-splitwise/landing
ADMIN_PANEL_CONTEXT=./admin-panel
WEB_CONTEXT=./web
BACKEND_ENV_FILE=.env.production

POSTGRES_DB=offline_splitwise
POSTGRES_USER=splitwise
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+psycopg://splitwise:change-me@postgres:5432/offline_splitwise

APP_NAME=OfflineSplitwise Backend
ENVIRONMENT=production
DEBUG=false
API_V1_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000

JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=14

ADMIN_PANEL_USERNAME=admin
ADMIN_PANEL_PASSWORD=
ADMIN_PANEL_PASSWORD_HASH=
ADMIN_PANEL_JWT_SECRET=change-me-to-a-long-random-admin-secret
ADMIN_PANEL_ACCESS_TOKEN_EXPIRE_MINUTES=480
ADMIN_PANEL_RATE_LIMIT_ATTEMPTS=5
ADMIN_PANEL_RATE_LIMIT_WINDOW_MINUTES=10
ADMIN_PANEL_RATE_LIMIT_LOCKOUT_MINUTES=15

PHONE_VERIFICATION_REQUIRED=false
SMS_IR_API_KEY=
SMS_IR_VERIFY_TEMPLATE_ID=
SMS_IR_VERIFY_TEMPLATE_ID_ANDROID=
SMS_IR_VERIFY_PARAMETER_NAME=OTP
SMS_IR_INVITED_ACCOUNT_TEMPLATE_ID=
SMS_IR_INVITED_ACCOUNT_LINK_PARAMETER_NAME=LINK
SMS_IR_INVITED_ACCOUNT_GROUP_NAME_PARAMETER_NAME=GROUP_NAME
WEB_APP_BASE_URL=https://pwa.splitwise.ir
PHONE_VERIFICATION_CODE_LENGTH=5
PHONE_VERIFICATION_TTL_SECONDS=120
PHONE_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
PHONE_VERIFICATION_MAX_VERIFY_ATTEMPTS=5
PHONE_VERIFICATION_MAX_SEND_ATTEMPTS_PER_WINDOW=3

APP_DOWNLOAD_ADMIN_SECRET=
APP_DOWNLOAD_UPLOAD_DIR=/files
APP_DOWNLOAD_PUBLIC_BASE_URL=https://api.splitwise.ir
ARTICLE_IMAGE_UPLOAD_DIR=/files/articles
ARTICLE_IMAGE_PUBLIC_BASE_URL=https://api.splitwise.ir

CORS_ALLOW_ORIGINS=https://splitwise.ir,https://www.splitwise.ir,https://panel.splitwise.ir,https://pwa.splitwise.ir
CORS_ALLOW_ORIGIN_REGEX=^https://([a-z0-9-]+\.)?splitwise\.ir$
CORS_ALLOW_CREDENTIALS=true

VITE_API_BASE_URL=https://api.splitwise.ir/api/v1
VITE_PHONE_VERIFICATION_REQUIRED=false
LANDING_ARTICLES_API_BASE_URL=https://api.splitwise.ir/api/v1
VITE_SHOW_ENAMAD=true

MAIL_HOSTNAME=mail.splitwise.ir
MAILSERVER_ENV_FILE=./deploy/mailserver/mailserver.env
ROUNDCUBEMAIL_DEFAULT_HOST=mailserver
ROUNDCUBEMAIL_DEFAULT_PORT=143
ROUNDCUBEMAIL_SMTP_SERVER=mailserver
ROUNDCUBEMAIL_SMTP_PORT=587
ROUNDCUBEMAIL_UPLOAD_MAX_FILESIZE=25M

BACKUP_INTERVAL_SECONDS=86400
BACKUP_RETENTION_DAYS=14
